{
  "name": "qualtrics-mcp-server",
  "version": "1.0.0",
  "description": "MCP server providing 53 tools for full Qualtrics API coverage",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "qualtrics-mcp-server": "src/index.ts"
  },
  "scripts": {
    "start": "tsx --env-file=.env src/index.ts",
    "dev": "tsx --watch src/index.ts",
    "typecheck": "tsgo --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "@typescript/native-preview": "latest",
    "tsx": "^4.19.4"
  },
  "license": "MIT"
}
